FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      omega;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 -1 0 0 0 0];

omegaInlet  0.4;

internalField   uniform $omegaInlet;

boundaryField
{
    front
    {
        type            cyclic;
    }

    back
    {
        type            cyclic;
    }

    left
    {
        type            cyclic;
    }

    right
    {
        type            cyclic;
    }

    bottom
    {
        type            omegaWallFunction;
        value           uniform $omegaInlet;
    }

    top
    {
        type            inletOutlet;
        inletValue      uniform $omegaInlet;
        value           uniform $omegaInlet;
    }
}

